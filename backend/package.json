{
  "name": "qx-serverless-api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start:local": "sam local start-api --template template.yaml --env-vars env.local.json",
    "db:migrate": "node dist/scripts/migrate.js"
  },
  "dependencies": {
    "@aws-sdk/rds-signer": "^3.1037.0",
    "jose": "^5.9.6",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/node": "^22.15.17",
    "@types/pg": "^8.15.5",
    "esbuild": "^0.28.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
